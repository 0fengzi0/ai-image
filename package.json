{
  "name": "ai-image-generator",
  "version": "1.0.0",
  "description": "OpenAI Responses API Image Generation with GPT-5.5",
  "main": "desktop/main.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:mirror": "electron-builder --win --x64 -c.electronDownload.mirror=https://npmmirror.com/mirrors/electron/"
  },
  "build": {
    "appId": "com.aiimage.generator",
    "productName": "AI Image Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "openai": "^4.47.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  }
}
